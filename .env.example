# MongoDB Atlas SRV connection string (recommended)
# Replace username, password and cluster host.
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority&appName=classmate

# Optional fallback key used by this app.
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority&appName=classmate

# Database used by the application
DB_NAME=classroom_management

# Fail fast when URI/network is incorrect (milliseconds)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
